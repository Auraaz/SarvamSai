# Copy to api/.env and repo root .env (server loads both). Never commit real secrets.

PORT=8787

# Razorpay (Dashboard → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxx

# Optional email (order notifications)
EMAIL_USER=your@email.com
EMAIL_PASS=your-app-password

# Optional — comma-separated extra browser origins allowed to call this API (CORS).
# Example: https://staging.sarvamsai.in,https://my-preview.pages.dev
# CORS_ORIGINS=
