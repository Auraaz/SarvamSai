# Copy to api/.env and repo root .env (server loads both). Never commit real secrets.

PORT=8787

# Razorpay — Dashboard → Developers → API keys (Test mode vs Live mode: use matching pair).
# Render: set these three on the web service Environment tab and redeploy if needed.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
# Webhooks → signing secret from Razorpay (can differ from key secret). If unset, server falls back to RAZORPAY_KEY_SECRET.
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxx
# Webhook URL (POST, application/json): https://api.sarvamsai.in/api/razorpay-webhook
# (also https://api.sarvamsai.in/razorpay-webhook — same handler)

# Optional email (order notifications)
EMAIL_USER=your@email.com
EMAIL_PASS=your-app-password

# Optional — comma-separated extra browser origins allowed to call this API (CORS).
# Example: https://staging.sarvamsai.in,https://my-preview.pages.dev
# CORS_ORIGINS=
